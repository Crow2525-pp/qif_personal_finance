          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH bucketed AS (\n  SELECT\n    CASE\n      WHEN abs_amount < 20 THEN '<$20'\n      WHEN abs_amount < 50 THEN '$20-49'\n      WHEN abs_amount < 100 THEN '$50-99'\n      WHEN abs_amount < 200 THEN '$100-199'\n      ELSE '$200+'\n    END AS \"Amount Category\",\n    abs_amount\n  FROM (\n    SELECT CASE WHEN t.amount < 0 THEN -t.amount ELSE t.amount END AS abs_amount\n    FROM reporting.reporting__fact_transactions t\n    JOIN reporting.dim_category c ON t.category_foreign_key = c.origin_key\n    WHERE c.store = 'Amazon'\n      AND t.date <= date_trunc('month', $__timeTo()::timestamp)\n  ) s\n),\nbase AS (\n  SELECT \"Amount Category\", SUM(abs_amount) AS \"Total Spending\"\n  FROM bucketed\n  GROUP BY \"Amount Category\"\n)\nSELECT * FROM base\nUNION ALL\nSELECT 'No Amazon data' AS \"Amount Category\", 0::numeric AS \"Total Spending\"\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY 2 DESC, 1;\n",
          "refId": "A"
        }
      ],
      "title": "Amazon Spending by Amount Category (2020-2025)",
