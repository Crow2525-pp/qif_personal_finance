          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    t.date::date AS \"Date\",\n    t.amount AS \"Amount\",\n    COALESCE(c.subcategory, 'Unknown') AS \"Amazon Type\",\n    CASE\n      WHEN ABS(t.amount) < 20 THEN '<$20'\n      WHEN ABS(t.amount) < 50 THEN '$20-49'\n      WHEN ABS(t.amount) < 100 THEN '$50-99'\n      WHEN ABS(t.amount) < 200 THEN '$100-199'\n      ELSE '$200+'\n    END AS \"Amount Category\",\n    COALESCE(NULLIF(TRIM(t.memo), ''), 'No Amazon transactions') AS \"Transaction Description\"\n  FROM reporting.reporting__fact_transactions t\n  JOIN reporting.dim_category c ON t.category_foreign_key = c.origin_key\n  WHERE c.store = 'Amazon'\n    AND t.date BETWEEN date_trunc('month', $__timeFrom()::timestamp) AND date_trunc('month', $__timeTo()::timestamp)\n  ORDER BY t.date DESC\n  LIMIT 50\n)\nSELECT * FROM base\nUNION ALL\nSELECT\n  date_trunc('month', $__timeTo()::timestamp)::date AS \"Date\",\n  0::numeric AS \"Amount\",\n  'N/A' AS \"Amazon Type\",\n  'N/A' AS \"Amount Category\",\n  'No Amazon transactions' AS \"Transaction Description\"\nWHERE NOT EXISTS (SELECT 1 FROM base);\n",
          "refId": "A"
        }
