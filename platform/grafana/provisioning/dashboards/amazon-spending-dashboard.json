          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    COALESCE(c.subcategory, 'Unknown') AS \"Product Category\",\n    COUNT(*) AS \"Transaction Count\",\n    SUM(CASE WHEN t.amount < 0 THEN -t.amount ELSE t.amount END) AS \"Total Spending\",\n    ROUND(AVG(CASE WHEN t.amount < 0 THEN -t.amount ELSE t.amount END), 2) AS \"Avg per Transaction\"\n  FROM reporting.reporting__fact_transactions t\n  JOIN reporting.dim_category c ON t.category_foreign_key = c.origin_key\n  WHERE c.store = 'Amazon'\n    AND t.date <= date_trunc('month', $__timeTo()::timestamp)\n  GROUP BY c.subcategory\n  ORDER BY \"Total Spending\" DESC\n  LIMIT 10\n)\nSELECT * FROM base\nUNION ALL\nSELECT\n  'No Amazon data' AS \"Product Category\",\n  0::bigint AS \"Transaction Count\",\n  0::numeric AS \"Total Spending\",\n  0::numeric AS \"Avg per Transaction\"\nWHERE NOT EXISTS (SELECT 1 FROM base);\n",
          "refId": "A"
        }
      ],
