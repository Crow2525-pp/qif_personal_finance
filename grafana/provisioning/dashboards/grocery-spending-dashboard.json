          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_month AS (  SELECT total_grocery_spend  FROM reporting.viz_grocery_monthly_summary  WHERE year_month >= date_trunc('month', $__timeFrom()::timestamp) AND year_month <= date_trunc('month', $__timeTo()::timestamp)  ORDER BY year_month DESC LIMIT 1) SELECT  ROUND(250 - COALESCE(total_grocery_spend, 0), 2) AS \"Budget Variance\",  ROUND((COALESCE(total_grocery_spend, 0) / 250) * 100, 1) AS \"% of Budget\" FROM latest_month UNION ALL SELECT 250::numeric, 0::numeric WHERE NOT EXISTS (SELECT 1 FROM latest_month)",
          "refId": "A"
        }
      ],
      "title": "Monthly Budget Target & Variance",
      "type": "stat"
    },
