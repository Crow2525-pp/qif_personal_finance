          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(coles_spend), 2) as \"Coles Avg\", ROUND(AVG(woolworths_spend), 2) as \"Woolworths Avg\", ROUND(AVG(gaskos_spend), 2) as \"Gaskos Avg\", ROUND(AVG(total_grocery_spend), 2) as \"Total Avg\" FROM reporting.viz_grocery_monthly_summary WHERE year_month >= date_trunc('month', $__timeFrom()::timestamp) AND year_month <= date_trunc('month', $__timeTo()::timestamp)",
