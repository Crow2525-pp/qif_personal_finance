          "rawQuery": true,
          "rawSql": "WITH store_averages AS (  SELECT grocery_store,    ROUND(AVG(monthly_spend), 2) AS avg_monthly_spend,    COUNT(*) AS months_tracked  FROM reporting.viz_grocery_spending_analysis  WHERE year_month >= date_trunc('month', $__timeFrom()::timestamp) AND year_month <= date_trunc('month', $__timeTo()::timestamp)  GROUP BY grocery_store), min_store AS (  SELECT grocery_store, avg_monthly_spend, months_tracked,    FIRST_VALUE(grocery_store) OVER (ORDER BY avg_monthly_spend) AS cheapest_store,    FIRST_VALUE(avg_monthly_spend) OVER (ORDER BY avg_monthly_spend) AS cheapest_price  FROM store_averages) SELECT grocery_store AS \"Store\",  avg_monthly_spend AS \"Avg Spend\",  ROUND(avg_monthly_spend - cheapest_price, 2) AS \"Premium Over Cheapest\",  months_tracked AS \"Months\" FROM min_store ORDER BY avg_monthly_spend ASC",
          "refId": "A"
        }
