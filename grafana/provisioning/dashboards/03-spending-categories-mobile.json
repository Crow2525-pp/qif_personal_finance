          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH aldi_monthly AS (\n    SELECT \n        DATE_TRUNC('month', transaction_date) as month,\n        ABS(SUM(transaction_amount)) as aldi_spend\n    FROM reporting.fct_transactions \n    WHERE transaction_memo ILIKE '%ALDI STORES%' \n        AND transaction_amount < 0 \n        AND transaction_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '18 months')\n    GROUP BY DATE_TRUNC('month', transaction_date)\n)\nSELECT \n    gms.year_month as time,\n    gms.coles_spend as \"Coles\",\n    gms.woolworths_spend as \"Woolworths\",\n    gms.gaskos_spend as \"Gaskos\",\n    COALESCE(am.aldi_spend, 0) as \"ALDI\",\n    gms.total_grocery_spend + COALESCE(am.aldi_spend, 0) as \"Total Grocery\"\nFROM reporting.viz_grocery_monthly_summary gms\nLEFT JOIN aldi_monthly am ON gms.year_month = am.month\nWHERE gms.year_month >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '18 months')\nORDER BY gms.year_month;",
          "refId": "A"
        }
      ],
      "title": "18-Month Grocery Spending Trends by Retailer",
      "type": "timeseries"
