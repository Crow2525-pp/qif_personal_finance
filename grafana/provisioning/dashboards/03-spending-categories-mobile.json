          "rawSql": "SELECT \n    period_date as time,\n    'Food & Drink' as metric,\n    \"Food & Drink\" as value\nFROM reporting.viz_spending_by_category_by_month\nWHERE period_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '12 months')\nUNION ALL\nSELECT \n    period_date as time,\n    'Household & Services' as metric,\n    \"Household & Services\" as value\nFROM reporting.viz_spending_by_category_by_month\nWHERE period_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '12 months')\nUNION ALL\nSELECT \n    period_date as time,\n    'Transport' as metric,\n    \"Transport\" as value\nFROM reporting.viz_spending_by_category_by_month\nWHERE period_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '12 months')\nUNION ALL\nSELECT \n    period_date as time,\n    'Shopping' as metric,\n    \"Shopping\" as value\nFROM reporting.viz_spending_by_category_by_month\nWHERE period_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '12 months')\nUNION ALL\nSELECT \n    period_date as time,\n    'Leisure' as metric,\n    \"Leisure\" as value\nFROM reporting.viz_spending_by_category_by_month\nWHERE period_date >= (date_trunc('month', $__timeTo()::timestamp) - INTERVAL '12 months')\nORDER BY time, metric;",
