      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PCC52D03280B7034C"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_month AS (\n  SELECT MAX(year_month) AS max_month\n  FROM reporting.viz_grocery_monthly_summary\n  WHERE year_month <= date_trunc('month', $__timeTo()::timestamp)\n),\naldi_current_month AS (\n  SELECT ABS(SUM(transaction_amount)) AS aldi_spend\n  FROM reporting.fct_transactions\n  WHERE transaction_memo ILIKE '%ALDI STORES%'\n    AND transaction_amount < 0\n    AND DATE_TRUNC('month', transaction_date) = (SELECT max_month FROM latest_month)\n),\nbase AS (\n  SELECT 'Coles' AS retailer, coles_spend AS value\n  FROM reporting.viz_grocery_monthly_summary gms\n  WHERE gms.year_month = (SELECT max_month FROM latest_month)\n    AND coles_spend > 0\n  UNION ALL\n  SELECT 'Woolworths', woolworths_spend\n  FROM reporting.viz_grocery_monthly_summary gms\n  WHERE gms.year_month = (SELECT max_month FROM latest_month)\n    AND woolworths_spend > 0\n  UNION ALL\n  SELECT 'Gaskos', gaskos_spend\n  FROM reporting.viz_grocery_monthly_summary gms\n  WHERE gms.year_month = (SELECT max_month FROM latest_month)\n    AND gaskos_spend > 0\n  UNION ALL\n  SELECT 'ALDI', COALESCE(aldi_spend, 0)\n  FROM aldi_current_month\n  WHERE COALESCE(aldi_spend, 0) > 0\n)\nSELECT * FROM base\nUNION ALL\nSELECT 'No grocery data' AS retailer, 0::numeric AS value\nWHERE NOT EXISTS (SELECT 1 FROM base);\n",
          "refId": "A"
        }
      ],
      "title": "Current Month Market Share",
      "type": "piechart"
    },
