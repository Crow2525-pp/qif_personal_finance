            "type": "postgres",
            "uid": "PCC52D03280B7034C"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    CASE\n      WHEN scenario = 'full_time' THEN 'Full-time Scenario'\n      WHEN scenario = 'part_time' THEN 'Part-time Scenario'\n      ELSE 'Other Scenario'\n    END AS \"Scenario\",\n    AVG(total_projected_income) AS \"Avg Monthly Income\",\n    AVG(projected_net_flow) AS \"Avg Net Flow\",\n    AVG(projected_savings_rate) AS \"Avg Savings Rate\"\n  FROM reporting.fct_financial_projections\n  WHERE projection_date BETWEEN date_trunc('month', $__timeFrom()::timestamp) AND date_trunc('month', $__timeTo()::timestamp)\n  GROUP BY scenario\n)\nSELECT * FROM base\nUNION ALL\nSELECT 'No projection data', 0::numeric, 0::numeric, 0::numeric\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY 1 DESC;\n",
          "refId": "A"
        }
      ],
      "title": "12-Month Average Projections by Scenario",
      "type": "table"
    },
