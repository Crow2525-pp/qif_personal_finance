      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PCC52D03280B7034C"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH full_time_income AS (\n    SELECT projection_date, total_projected_income as full_income\n    FROM reporting.fct_financial_projections WHERE scenario = 'full_time'\n    AND projection_date >= $__timeTo()::date\n    AND projection_date <= $__timeTo()::date + INTERVAL '12 months'\n),\npart_time_income AS (\n    SELECT projection_date, total_projected_income as part_income\n    FROM reporting.fct_financial_projections WHERE scenario = 'part_time'\n    AND projection_date >= $__timeTo()::date\n    AND projection_date <= $__timeTo()::date + INTERVAL '12 months'\n)\nSELECT \n    COALESCE(SUM(ft.full_income - pt.part_income), 0) as \"Part-time Opportunity Cost (12 Months)\"\nFROM full_time_income ft\nFULL OUTER JOIN part_time_income pt ON ft.projection_date = pt.projection_date;",
          "refId": "A"
        }
      ],
      "title": "12-Month Part-time Opportunity Cost",
      "type": "stat"
    },
