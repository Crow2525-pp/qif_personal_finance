          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH latest_year AS (\n  SELECT MAX(comparison_year) AS comparison_year\n  FROM reporting.rpt_year_over_year_comparison\n  WHERE comparison_year <= EXTRACT(YEAR FROM $__timeTo()::timestamp)::int\n),\nbase AS (\n  SELECT\n    TO_TIMESTAMP(comparison_year || '-12-31', 'YYYY-MM-DD')::date AS time,\n    annual_income AS \"Annual Income\",\n    annual_expenses AS \"Annual Expenses\",\n    annual_net_cash_flow AS \"Annual Net Flow\"\n  FROM reporting.rpt_year_over_year_comparison\n  WHERE comparison_year BETWEEN GREATEST((SELECT comparison_year FROM latest_year) - 3, 0) AND (SELECT comparison_year FROM latest_year)\n)\nSELECT * FROM base\nUNION ALL\nSELECT date_trunc('year', $__timeTo()::timestamp)::date AS time, 0::numeric, 0::numeric, 0::numeric\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY time;\n",
