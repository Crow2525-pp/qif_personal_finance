      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "PCC52D03280B7034C"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH latest_year AS (\n  SELECT MAX(SUBSTRING(budget_year_month, 1, 4)::int) AS report_year\n  FROM reporting.rpt_savings_analysis\n  WHERE budget_year_month <= TO_CHAR(date_trunc('month', $__timeTo()::timestamp), 'YYYY-MM')\n),\ncurrent_year_data AS (\n  SELECT\n    TO_DATE(budget_year_month || '-01', 'YYYY-MM-DD') AS time,\n    total_savings_rate_percent AS \"Current Year\"\n  FROM reporting.rpt_savings_analysis\n  WHERE SUBSTRING(budget_year_month, 1, 4)::int = (SELECT report_year FROM latest_year)\n),\nprevious_year_data AS (\n  SELECT\n    (TO_DATE(budget_year_month || '-01', 'YYYY-MM-DD') + INTERVAL '1 year')::date AS time,\n    total_savings_rate_percent AS \"Previous Year\"\n  FROM reporting.rpt_savings_analysis\n  WHERE SUBSTRING(budget_year_month, 1, 4)::int = (SELECT report_year - 1 FROM latest_year)\n),\nbase AS (\n  SELECT\n    COALESCE(cy.time, py.time) AS time,\n    cy.\"Current Year\",\n    py.\"Previous Year\"\n  FROM current_year_data cy\n  FULL OUTER JOIN previous_year_data py ON cy.time = py.time\n)\nSELECT * FROM base\nUNION ALL\nSELECT date_trunc('month', $__timeTo()::timestamp)::date AS time, 0::numeric, 0::numeric\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY time;\n",
          "refId": "A"
        }
      ],
      "title": "Year-over-Year Savings Rate Comparison",
      "type": "timeseries"
    },
