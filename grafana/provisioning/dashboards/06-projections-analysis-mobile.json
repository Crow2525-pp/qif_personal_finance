          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH base AS (\n  SELECT\n    projection_date AS time,\n    CASE WHEN scenario = 'full_time' THEN projected_net_flow ELSE NULL END AS \"Full-time Net Flow\",\n    CASE WHEN scenario = 'part_time' THEN projected_net_flow ELSE NULL END AS \"Part-time Net Flow\"\n  FROM reporting.fct_financial_projections\n  WHERE projection_date BETWEEN date_trunc('month', $__timeFrom()::timestamp) AND date_trunc('month', $__timeTo()::timestamp)\n  ORDER BY projection_date\n)\nSELECT * FROM base\nUNION ALL\nSELECT\n  date_trunc('month', $__timeFrom()::timestamp) AS time,\n  0::numeric AS \"Full-time Net Flow\",\n  0::numeric AS \"Part-time Net Flow\"\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY time;\n",
          "refId": "A"
        }
      ],
      "title": "12-Month Financial Projections: Full-time vs Part-time Scenarios",
      "type": "timeseries"
    },
