          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_year AS (\n  SELECT MAX(comparison_year) AS comparison_year\n  FROM reporting.rpt_year_over_year_comparison\n  WHERE comparison_year <= EXTRACT(YEAR FROM $__timeTo()::timestamp)::int\n),\nbase AS (\n  SELECT 'Total Income' AS \"Financial Metric\", annual_income AS \"Current YTD\", prev_year_income AS \"Previous YTD\", yoy_income_change_percent AS \"YoY Change %\" FROM reporting.rpt_year_over_year_comparison WHERE comparison_year = (SELECT comparison_year FROM latest_year)\n  UNION ALL\n  SELECT 'Total Expenses', annual_expenses, prev_year_expenses, yoy_expense_change_percent FROM reporting.rpt_year_over_year_comparison WHERE comparison_year = (SELECT comparison_year FROM latest_year)\n  UNION ALL\n  SELECT 'Net Cash Flow', annual_net_cash_flow, prev_year_income - prev_year_expenses, CASE WHEN (prev_year_income - prev_year_expenses) != 0 THEN (annual_net_cash_flow - (prev_year_income - prev_year_expenses)) / ABS(prev_year_income - prev_year_expenses) ELSE NULL END FROM reporting.rpt_year_over_year_comparison WHERE comparison_year = (SELECT comparison_year FROM latest_year)\n  UNION ALL\n  SELECT 'Avg Savings Rate', avg_savings_rate_percent, prev_year_savings_rate, yoy_savings_rate_change FROM reporting.rpt_year_over_year_comparison WHERE comparison_year = (SELECT comparison_year FROM latest_year)\n)\nSELECT * FROM base\nUNION ALL\nSELECT 'No comparison data' AS \"Financial Metric\", 0::numeric, 0::numeric, 0::numeric\nWHERE NOT EXISTS (SELECT 1 FROM base);\n",
          "refId": "A"
        }
      ],
      "title": "Year-to-Date Performance vs Previous Year (Same Period)",
      "type": "table"
