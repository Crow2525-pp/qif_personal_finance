          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT *\n  FROM reporting.rpt_executive_dashboard\n  WHERE dashboard_month <= TO_CHAR(date_trunc('month', $__timeTo()::timestamp), 'YYYY-MM')\n  ORDER BY dashboard_month DESC\n  LIMIT 1\n)\nSELECT\n  ROUND(overall_financial_health_score, 0) AS \"Financial Health\",\n  ROUND(GREATEST(0, 100 - expense_to_income_ratio_pct), 0) AS \"Expense Control\",\n  ROUND(savings_health_score, 0) AS \"Savings Efficiency\",\n  ROUND(cash_flow_score, 0) AS \"Cash Flow Score\"\nFROM latest\nUNION ALL\nSELECT 0::numeric, 0::numeric, 0::numeric, 0::numeric\nWHERE NOT EXISTS (SELECT 1 FROM latest);\n",
          "refId": "A"
        }
      ],
      "title": "Health Scores",
      "type": "bargauge"
