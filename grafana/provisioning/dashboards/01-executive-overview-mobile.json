          "rawSql": "WITH latest AS (\n  SELECT MAX(period_date) AS p\n  FROM reporting.rpt_financials_reconciliation_tests\n  WHERE period_date <= date_trunc('month', $__timeTo()::timestamp)\n),\nbase AS (\n  SELECT\n    domain,\n    COUNT(*) FILTER (WHERE pass) AS passed,\n    COUNT(*) FILTER (WHERE NOT pass) AS failed,\n    COUNT(*) AS total\n  FROM reporting.rpt_financials_reconciliation_tests\n  WHERE period_date = (SELECT p FROM latest)\n  GROUP BY domain\n)\nSELECT * FROM base\nUNION ALL\nSELECT 'No reconciliation data' AS domain, 0::bigint AS passed, 0::bigint AS failed, 0::bigint AS total\nWHERE NOT EXISTS (SELECT 1 FROM base)\nORDER BY domain;\n",
          "refId": "A"
        }
